				{
					"name": "Add to Cart",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"product_id\": 1,\n    \"quantity\": 2,\n    \"size\": \"M\",\n    \"color\": \"Red\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/cart/add",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"cart",
								"add"
							]
						},
						"description": "Add product to cart with variant (size & color).\n\n**Fields:**\n- `product_id` (required): Product ID\n- `quantity` (required): Quantity to add\n- `size` (optional): Size from sizeStockPairs array of the variant\n- `color` (optional): Variant color (hex code) from attributes\n\n**Note:** \n- System matches variant by `color` first\n- Then finds the specific `size` in that variant's `sizeStockPairs` array\n- If size/color not provided, first variant and first sizeStockPair will be used automatically\n- Stock is checked from the specific sizeStockPair entry"
					},
					"response": []
				},
				{
					"name": "Add to Cart (Without Variants)",
					"request": {
						"auth": {
							"type": "bearer",
