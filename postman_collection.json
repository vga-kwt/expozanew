							"mode": "formdata",
							"formdata": [
								{
									"key": "name_en",
									"value": "Test Product",
									"type": "text"
								},
								{
									"key": "name_ar",
									"value": "منتج تجريبي",
									"type": "text"
								},
								{
									"key": "description_en",
									"value": "Test product description",
									"type": "text"
								},
								{
									"key": "description_ar",
									"value": "وصف المنتج التجريبي",
									"type": "text"
								},
								{
									"key": "regular_price",
									"value": "0",
									"type": "text"
								},
								{
									"key": "sale_price",
									"value": "0",
									"type": "text"
								},
								{
									"key": "stock",
									"value": "0",
									"type": "text"
								},
								{
									"key": "category_id",
									"value": "1",
									"type": "text"
								},
								{
									"key": "status",
									"value": "active",
									"type": "text"
								},
								{
									"key": "attributes",
									"value": "[{\"color\":\"#FF0000\",\"price\":150,\"sale_price\":150,\"stock\":0,\"sizeStockPairs\":[{\"size\":\"S\",\"stock\":5},{\"size\":\"M\",\"stock\":10},{\"size\":\"L\",\"stock\":8}]},{\"color\":\"#0000FF\",\"price\":150,\"sale_price\":150,\"stock\":0,\"sizeStockPairs\":[{\"size\":\"M\",\"stock\":10},{\"size\":\"L\",\"stock\":15}]}]",
									"type": "text",
									"description": "JSON array of variants with color, price, sale_price, stock, and sizeStockPairs array. Each sizeStockPairs entry contains size and stock."
								},
								{
									"key": "image_url",
									"type": "file",
									"src": []
								},
								{
									"key": "gallery[]",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/products",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"products"
							]
						},
						"description": "Create product with variants stored in attributes field.\n\n**Variants Format (JSON):**\n```json\n[\n  {\n    \"color\": \"#FF0000\",\n    \"price\": 150,\n    \"sale_price\": 150,\n    \"stock\": 0,\n    \"sizeStockPairs\": [\n      {\"size\": \"S\", \"stock\": 5},\n      {\"size\": \"M\", \"stock\": 10},\n      {\"size\": \"L\", \"stock\": 8}\n    ]\n  },\n  {\n    \"color\": \"#0000FF\",\n    \"price\": 150,\n    \"sale_price\": 150,\n    \"stock\": 0,\n    \"sizeStockPairs\": [\n      {\"size\": \"M\", \"stock\": 10},\n      {\"size\": \"L\", \"stock\": 15}\n    ]\n  }\n]\n```\n\n**Note:** \n- Each variant has a `color` (hex code), `price`, `sale_price`, and `sizeStockPairs` array\n- Each `sizeStockPairs` entry contains `size` and `stock` for that specific size\n- Total stock from all variants and sizeStockPairs will be calculated and stored in `stock` field"
					},
					"response": []
				},
				{
					"name": "Update Product Variants",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "_method",
									"value": "PUT",
									"type": "text"
								},
								{
									"key": "name_en",
									"value": "Updated Product",
									"type": "text"
								},
								{
									"key": "name_ar",
									"value": "منتج محدث",
									"type": "text"
								},
								{
									"key": "attributes",
									"value": "[{\"color\":\"#FF0000\",\"price\":200,\"sale_price\":180,\"stock\":0,\"sizeStockPairs\":[{\"size\":\"S\",\"stock\":8},{\"size\":\"M\",\"stock\":15},{\"size\":\"L\",\"stock\":12}]},{\"color\":\"#0000FF\",\"price\":200,\"sale_price\":180,\"stock\":0,\"sizeStockPairs\":[{\"size\":\"M\",\"stock\":20},{\"size\":\"L\",\"stock\":25}]}]",
									"type": "text",
									"description": "Updated variants JSON with sizeStockPairs structure"
								},
								{
									"key": "stock",
									"value": "0",
									"type": "text",
									"description": "Will be auto-calculated from variants"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/products/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"products",
								"1"
							]
						},
						"description": "Update product variants with sizeStockPairs structure. Total stock will be recalculated from all variants and their sizeStockPairs.\n\n**Variants Format:**\n```json\n[\n  {\n    \"color\": \"#FF0000\",\n    \"price\": 200,\n    \"sale_price\": 180,\n    \"stock\": 0,\n    \"sizeStockPairs\": [\n      {\"size\": \"S\", \"stock\": 8},\n      {\"size\": \"M\", \"stock\": 15},\n      {\"size\": \"L\", \"stock\": 12}\n    ]\n  }\n]\n```"
					},
					"response": []
				},
